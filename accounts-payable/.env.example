# ─────────────────────────────────────────────
# CONFIGURACIÓN AGENTE ACCOUNTS-PAYABLE (AP) - ISBEROAL
# ─────────────────────────────────────────────
# IMPORTANTE: este archivo es solo una plantilla.
# Copialo a `.env` y rellena los valores reales.
# El archivo `.env` NUNCA debe subirse a Git.


# ─── REQUERIDAS (siempre) ────────────────────────────

# API Key de Holded
# Holded > Configuración > API > Tu API Key
HOLDED_API_KEY=""

# API Key de Anthropic (para OCR con Claude Vision)
# https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Ruta al archivo credentials.json de Google OAuth (Desktop)
# Descargado de Google Cloud Console > APIs y servicios > Credenciales
GOOGLE_CREDENTIALS_PATH="credentials.json"


# ─── OPCIONALES (modo Railway / produccion headless) ─

# JSON completo del token Gmail. Si está presente, el agente
# no necesita token.json en disco ni navegador para autenticarse.
# Se genera una vez en local con el flujo OAuth interactivo
# y luego se copia su contenido aquí (o a variables de Railway).
# Ejemplo de valor: {"token":"...","refresh_token":"...","client_id":"..."}
GMAIL_TOKEN_JSON=""

# Si está definida con cualquier valor, el agente:
#   - Envía logs solo a stdout (no a archivo, sistema efímero).
#   - Si no encuentra credenciales válidas, lanza RuntimeError
#     en lugar de intentar abrir un navegador (que no existe).
# Railway define esta variable automáticamente.
RAILWAY_ENVIRONMENT=""

# Si vale "true", el agente fuerza modo seguro:
#   - solo_xlsx = True
#   - importar_holded = False
# Útil para validar Railway en paralelo al agente local
# sin riesgo de duplicar facturas en Holded.
ISBEROAL_SHADOW_MODE=""
