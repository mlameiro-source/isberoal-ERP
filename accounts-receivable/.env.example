# ─────────────────────────────────────────────
# CONFIGURACIÓN AGENTE COBROS (AR) - ISBEROAL
# ─────────────────────────────────────────────
# IMPORTANTE: Este archivo nunca debe subirse a Git ni compartirse
# Copia este fichero como `.env` y rellena los valores reales.

# ── API Key de Holded ────────────────────────
# Encuéntrala en: Holded > Configuración > API > Tu API Key
HOLDED_API_KEY=""

# ── API Key de Anthropic ─────────────────────
# Para parsear prompts en lenguaje natural y crear borradores
# Obtenla en: https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ── Credenciales de Google (OAuth Desktop) ──
# Ruta al archivo credentials.json descargado de Google Cloud Console.
# Puede reutilizarse el del proyecto Accounts-Payable (mismo cliente OAuth).
GOOGLE_CREDENTIALS_PATH="credentials.json"

# ── Google Sheets ────────────────────────────
# Si está vacío, el agente CREA un Spreadsheet nuevo en Drive y escribe aquí su ID.
# Si quieres usar uno existente, pégalo aquí (lo ves en la URL del Sheet).
SPREADSHEET_ID=""

# Título del Spreadsheet a crear si no existe
SPREADSHEET_TITLE="Isberoal AR — Cuentas a cobrar"

# ── Alertas por email ────────────────────────
# Destinatario de los emails de alerta (separar varios con comas)
ALERT_EMAIL_TO="contabilidad@isberoal.com"
# Remitente: lo deja a la cuenta autorizada en OAuth (no se usa SMTP)

# ── Comportamiento ───────────────────────────
# warning  → permite crear hito 2 aunque el 1 no esté cobrado, solo avisa
# strict   → bloquea creación si el hito anterior no está cobrado
HITO_VALIDATION_MODE="warning"
